{
    "type": "APL",
    "version": "2024.3",
    "import": [
        {
            "name": "alexa-layouts",
            "version": "1.7.0"
        }
    ],
    "mainTemplate": {
        "parameters": [
            "matchData"
        ],
        "items": [
            {
                "type": "Container",
                "width": "100%",
                "height": "100%",
                "theme": "light",
                "items": [
                    {
                        "type": "Image",
                        "source": "https://bartualfdez.asuscomm.com/blindfoldchess/assets/images/background.png",
                        "scale": "best-fill",
                        "width": "100%",
                        "height": "100%",
                        "position": "absolute"
                    },
                    {
                        "type": "AlexaHeader",
                        "headerTitle": "${matchData.title}",
                        "headerSubtitle": "${matchData.subtitle}",
                        "headerAttributionImage": "${matchData.logoUrl}",
                        "headerBackButton": true,
                        "onHeaderBackButton": [
                            {
                                "type": "SendEvent",
                                "arguments": [
                                    "goBack"
                                ]
                            }
                        ],
                        "theme": "light"
                    },
                    {
                        "type": "Container",
                        "direction": "row",
                        "grow": 1,
                        "paddingLeft": "@spacingMedium",
                        "paddingRight": "@spacingMedium",
                        "items": [
                            {
                                "type": "Container",
                                "width": "70%",
                                "height": "100%",
                                "paddingLeft": "5%",
                                "justifyContent": "center",
                                "items": [
                                    {
                                        "type": "Image",
                                        "source": "${matchData.boardUrl}",
                                        "scale": "best-fit",
                                        "width": "100%",
                                        "height": "80%",
                                        "aspectRatio": 1
                                    },
                                    {
                                        "type": "Text",
                                        "text": "${matchData.lastMove}",
                                        "style": "textStyleBody",
                                        "textAlign": "center",
                                        "marginTop": "@spacingSmall",
                                        "color": "#1a1a1a",
                                        "when": "${matchData.lastMove != ''}"
                                    }
                                ]
                            },
                            {
                                "type": "Container",
                                "width": "30%",
                                "height": "100%",
                                "paddingLeft": "@spacingMedium",
                                "paddingRight": "@spacingMedium",
                                "items": [
                                    {
                                        "type": "Sequence",
                                        "grow": 1,
                                        "marginTop": "@spacingSmall",
                                        "data": "${matchData.moveHistory}",
                                        "item": {
                                            "type": "Container",
                                            "direction": "row",
                                            "paddingBottom": "@spacingXSmall",
                                            "items": [
                                                {
                                                    "type": "Text",
                                                    "text": "${data.number}",
                                                    "width": "25%",
                                                    "style": "textStyleBody",
                                                    "color": "#4a4a4a",
                                                    "fontWeight": "bold"
                                                },
                                                {
                                                    "type": "Text",
                                                    "text": "${data.white}",
                                                    "width": "37.5%",
                                                    "style": "textStyleBody",
                                                    "color": "#1a1a1a"
                                                },
                                                {
                                                    "type": "Text",
                                                    "text": "${data.black}",
                                                    "width": "37.5%",
                                                    "style": "textStyleBody",
                                                    "color": "#1a1a1a"
                                                }
                                            ]
                                        }
                                    },
                                    {
                                        "type": "Text",
                                        "text": "${matchData.status}",
                                        "style": "textStyleBody",
                                        "fontWeight": "bold",
                                        "color": "red",
                                        "marginTop": "@spacingMedium",
                                        "when": "${matchData.status != ''}"
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    }
}
