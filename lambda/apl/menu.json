{
  "type": "APL",
  "version": "1.7",
  "import": [
    {
      "name": "alexa-layouts",
      "version": "1.7.0"
    }
  ],
  "mainTemplate": {
    "parameters": [
      "payload"
    ],
    "items": [
      {
        "type": "Container",
        "width": "100vw",
        "height": "100vh",
        "backgroundColor": "#F0F0F2",
        "items": [
          {
            "type": "Frame",
            "position": "absolute",
            "width": "100%",
            "height": "100%",
            "background": {
              "type": "linear-gradient",
              "colorRange": [
                "#FFFFFF",
                "#E8E8EB",
                "#D1D1D4"
              ],
              "angle": 135
            }
          },
          {
            "type": "Container",
            "width": "100%",
            "height": "100%",
            "alignItems": "center",
            "justifyContent": "center",
            "padding": "40dp",
            "items": [
              {
                "type": "Text",
                "text": "BLINDFOLD CHESS",
                "fontSize": "42dp",
                "fontWeight": "900",
                "color": "#1A1A1C",
                "letterSpacing": "6dp",
                "paddingBottom": "10dp"
              },
              {
                "type": "Text",
                "text": "Choose your training mode",
                "fontSize": "18dp",
                "fontWeight": "400",
                "color": "#6E6E73",
                "paddingBottom": "50dp"
              },
              {
                "type": "Container",
                "flexDirection": "row",
                "width": "100%",
                "justifyContent": "center",
                "items": [
                  {
                    "type": "TouchWrapper",
                    "width": "20vw",
                    "height": "35vh",
                    "onPress": [
                      {
                        "type": "SendEvent",
                        "arguments": [
                          "SwitchModeIntent",
                          {
                            "mode": "matches"
                          }
                        ]
                      }
                    ],
                    "item": {
                      "type": "Frame",
                      "width": "100%",
                      "height": "100%",
                      "borderRadius": "30dp",
                      "backgroundColor": "#FFFFFFE6" ,
                      "borderWidth": "1dp",
                      "borderColor": "#00000010",
                      "shadowColor": "#00000020",
                      "shadowOffset": { "width": 0, "height": 10 },
                      "shadowRadius": "20dp",
                      "items": [
                        {
                          "type": "Container",
                          "width": "100%",
                          "height": "100%",
                          "alignItems": "center",
                          "justifyContent": "center",
                          "padding": "20dp",
                          "items": [
                            {
                              "type": "Text",
                              "text": "♔",
                              "fontSize": "70dp",
                              "color": "#1D1D1F"
                            },
                            {
                              "type": "Text",
                              "text": "${payload.menuData.matchesText}",
                              "fontSize": "18dp",
                              "fontWeight": "700",
                              "color": "#1D1D1F",
                              "textAlign": "center",
                              "paddingTop": "15dp"
                            }
                          ]
                        }
                      ]
                    }
                  },
                  { "type": "Container", "width": "3vw" },
                  {
                    "type": "TouchWrapper",
                    "width": "20vw",
                    "height": "35vh",
                    "onPress": [
                      {
                        "type": "SendEvent",
                        "arguments": [
                          "SwitchModeIntent",
                          {
                            "mode": "puzzles"
                          }
                        ]
                      }
                    ],
                    "item": {
                      "type": "Frame",
                      "width": "100%",
                      "height": "100%",
                      "borderRadius": "30dp",
                      "backgroundColor": "#FFFFFFE6",
                      "borderWidth": "1dp",
                      "borderColor": "#00000010",
                      "shadowColor": "#00000020",
                      "shadowOffset": { "width": 0, "height": 10 },
                      "shadowRadius": "20dp",
                      "items": [
                        {
                          "type": "Container",
                          "width": "100%",
                          "height": "100%",
                          "alignItems": "center",
                          "justifyContent": "center",
                          "padding": "20dp",
                          "items": [
                            {
                              "type": "Text",
                              "text": "🧩",
                              "fontSize": "70dp",
                              "color": "#1D1D1F"
                            },
                            {
                              "type": "Text",
                              "text": "${payload.menuData.puzzlesText}",
                              "fontSize": "18dp",
                              "fontWeight": "700",
                              "color": "#1D1D1F",
                              "textAlign": "center",
                              "paddingTop": "15dp"
                            }
                          ]
                        }
                      ]
                    }
                  },
                  { "type": "Container", "width": "3vw" },
                  {
                    "type": "TouchWrapper",
                    "width": "20vw",
                    "height": "35vh",
                    "onPress": [
                      {
                        "type": "SendEvent",
                        "arguments": [
                          "SwitchModeIntent",
                          {
                            "mode": "squares"
                          }
                        ]
                      }
                    ],
                    "item": {
                      "type": "Frame",
                      "width": "100%",
                      "height": "100%",
                      "borderRadius": "30dp",
                      "backgroundColor": "#FFFFFFE6",
                      "borderWidth": "1dp",
                      "borderColor": "#00000010",
                      "shadowColor": "#00000020",
                      "shadowOffset": { "width": 0, "height": 10 },
                      "shadowRadius": "20dp",
                      "items": [
                        {
                          "type": "Container",
                          "width": "100%",
                          "height": "100%",
                          "alignItems": "center",
                          "justifyContent": "center",
                          "padding": "20dp",
                          "items": [
                            {
                              "type": "Text",
                              "text": "🏁",
                              "fontSize": "70dp",
                              "color": "#1D1D1F"
                            },
                            {
                              "type": "Text",
                              "text": "${payload.menuData.squaresText}",
                              "fontSize": "18dp",
                              "fontWeight": "700",
                              "color": "#1D1D1F",
                              "textAlign": "center",
                              "paddingTop": "15dp"
                            }
                          ]
                        }
                      ]
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
