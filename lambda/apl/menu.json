{
  "type": "APL",
  "version": "1.7",
  "import": [
    {
      "name": "alexa-layouts",
      "version": "1.7.0"
    }
  ],
  "mainTemplate": {
    "parameters": [
      "payload"
    ],
    "items": [
      {
        "type": "AlexaImageList",
        "id": "menuList",
        "headerTitle": "${payload.menuData.title}",
        "headerBackButton": false,
        "headerDivider": true,
        "backgroundImageSource": "https://img.freepik.com/free-photo/white-marble-texture-background-high-resolution_34261-755.jpg",
        "backgroundBlur": false,
        "backgroundColorOverlay": true,
        "imageAspectRatio": "square",
        "imageMetadataPrimacy": true,
        "imageScale": "best-fit",
        "listItems": "${payload.menuData.listItems}",
        "primaryAction": [
          {
            "type": "SendEvent",
            "arguments": [
              "SwitchModeIntent",
              "${event.source.value}"
            ]
          }
        ]
      }
    ]
  }
}
