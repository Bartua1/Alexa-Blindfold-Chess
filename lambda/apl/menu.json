{
  "type": "APL",
  "version": "2024.3",
  "theme": "light",
  "import": [
    {
      "name": "alexa-layouts",
      "version": "1.7.0"
    }
  ],
  "mainTemplate": {
    "parameters": [
      "imageListData"
    ],
    "items": [
      {
        "type": "AlexaImageList",
        "id": "menuList",
        "theme": "light",
        "headerTitle": "${imageListData.title}",
        "headerBackButton": false,
        "headerDivider": true,
        "backgroundColor": "white",
        "backgroundImageSource": "https://bartualfdez.asuscomm.com/blindfoldchess/assets/images/background.png",
        "backgroundBlur": false,
        "backgroundColorOverlay": false,
        "imageAspectRatio": "square",
        "imageMetadataPrimacy": true,
        "imageScale": "best-fit",
        "listItems": "${imageListData.listItems}",
        "primaryAction": [
          {
            "type": "SendEvent",
            "arguments": [
              "SwitchModeIntent",
              "${data.value}"
            ]
          }
        ]
      }
    ]
  }
}
