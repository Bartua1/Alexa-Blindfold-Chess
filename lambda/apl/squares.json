{
    "type": "APL",
    "version": "2024.3",
    "license": "Copyright 2024 Amazon.com, Inc. or its affiliates. All Rights Reserved.\nSPDX-License-Identifier: LicenseRef-.amazon.com.-AmznSL-1.0\nLicensed under the Amazon Software License  http://aws.amazon.com/asl/",
    "import": [
        {
            "name": "alexa-layouts",
            "version": "1.7.0"
        }
    ],
    "mainTemplate": {
        "parameters": [
            "squaresData"
        ],
        "items": [
            {
                "type": "AlexaDetail",
                "id": "squaresDetail",
                "detailType": "location",
                "detailImageAlignment": "left",
                "headerTitle": "${squaresData.title}",
                "headerSubtitle": "${squaresData.feedback}",
                "headerBackButton": true,
                "headerAttributionImage": "${squaresData.logoUrl}",
                "imageBlurredBackground": false,
                "imageScale": "best-fit",
                "imageAspectRatio": "square",
                "imageAlignment": "right",
                "imageSource": "${squaresData.boardUrl}",
                "imageCaption": "Chessboard",
                "primaryText": "${squaresData.currentQuestion}",
                "ratingSlotMode": "multiple",
                "ratingNumber": 0,
                "ratingText": "",
                "locationText": "",
                "secondaryText": "${squaresData.timeText}",
                "button1Text": "Next",
                "button2Text": "Stop",
                "button1Theme": "dark",
                "button2Theme": "dark",
                "backgroundImageSource": "https://bartualfdez.asuscomm.com/blindfoldchess/assets/images/background.png",
                "theme": "dark"
            }
        ]
    }
}
