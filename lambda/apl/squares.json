{
  "type": "APL",
  "version": "2024.3",
  "theme": "light",
  "import": [
    {
      "name": "alexa-layouts",
      "version": "1.7.0"
    }
  ],
  "mainTemplate": {
    "parameters": [
      "squaresData"
    ],
    "items": [
      {
        "type": "Container",
        "width": "100%",
        "height": "100%",
        "items": [
          {
            "type": "AlexaBackground",
            "backgroundImageSource": "https://bartualfdez.asuscomm.com/blindfoldchess/assets/images/background.png",
            "backgroundOverlay": true,
            "backgroundBlur": false
          },
          {
            "type": "AlexaHeader",
            "headerTitle": "${squaresData.title}",
            "headerDivider": true,
            "theme": "light"
          },
          {
            "type": "Container",
            "width": "100%",
            "flexGrow": 1,
            "flexDirection": "row",
            "paddingLeft": "4vw",
            "paddingRight": "4vw",
            "alignItems": "center",
            "justifyContent": "center",
            "items": [
              {
                "type": "Container",
                "width": "50%",
                "height": "100%",
                "alignItems": "center",
                "justifyContent": "center",
                "items": [
                  {
                    "type": "Frame",
                    "width": "60vh",
                    "height": "60vh",
                    "maxWidth": "44vw",
                    "maxHeight": "44vw",
                    "borderRadius": "24dp",
                    "backgroundColor": "white",
                    "shadowColor": "black",
                    "shadowOffset": { "width": 0, "height": 4 },
                    "shadowRadius": "12dp",
                    "padding": "12dp",
                    "item": {
                      "type": "Image",
                      "source": "${squaresData.boardUrl}",
                      "width": "100%",
                      "height": "100%",
                      "scale": "best-fit",
                      "opacity": "${squaresData.boardUrl == '' || squaresData.boardUrl == null ? 0 : 1}"
                    }
                  }
                ]
              },
              {
                "type": "Container",
                "width": "45%",
                "height": "100%",
                "paddingLeft": "4vw",
                "alignItems": "center",
                "justifyContent": "center",
                "items": [
                  {
                    "type": "Frame",
                    "width": "100%",
                    "borderRadius": "16dp",
                    "backgroundColor": "${squaresData.isCorrect ? '#E8F5E9' : '#FFEBEE'}",
                    "padding": "20dp",
                    "display": "${squaresData.feedback ? 'flex' : 'none'}",
                    "item": {
                      "type": "Text",
                      "text": "${squaresData.feedback}",
                      "color": "${squaresData.isCorrect ? '#2E7D32' : '#C62828'}",
                      "fontSize": "4vw",
                      "fontWeight": "bold",
                      "textAlign": "center"
                    }
                  },
                  {
                    "type": "Text",
                    "text": "${squaresData.currentQuestion}",
                    "color": "#212121",
                    "fontSize": "3.5vw",
                    "fontWeight": "600",
                    "paddingTop": "4vh",
                    "textAlign": "center",
                    "width": "100%"
                  }
                ]
              }
            ]
          },
          {
            "type": "AlexaFooter",
            "footerHint": "${squaresData.isCorrect ? 'Correct! Say next to continue' : 'Try the next one!'}",
            "theme": "light"
          }
        ]
      }
    ]
  }
}
